# Configuración de la base de datos MongoDB
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# Configuración del servidor
PORT=5000
NODE_ENV=development

# Orígenes permitidos por CORS (separados por comas). Si se deja vacío, se permite todo (solo dev).
# Ejemplo: FRONTEND_URL=http://localhost:5173,https://miweb.com
FRONTEND_URL=

# Configuración de Cloudinary para subida de archivos
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Configuración de JWT para autenticación
JWT_SECRET=tu_jwt_secret_super_seguro
JWT_EXPIRE=1h

# Brevo para envío de correos (recuperación de contraseña) - API HTTP
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx
# Correo remitente verificado en Brevo (Senders). Puede ser tu propio correo.
BREVO_FROM_EMAIL=tu_correo_verificado@gmail.com
# Nombre que se mostrará como remitente (opcional)
BREVO_FROM_NAME=La Aterciopelada
